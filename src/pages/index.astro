---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>Ember & Salt — Fire. Flavour. Florida Road. | Berea, Durban</title>
  <meta name="description" content="Wood-fire cooking on Florida Road, Berea, Durban. Local ingredients. Good people. Reserve your table at Ember & Salt." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Preload fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Jost:wght@300;400;500;600&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>

<body>

<!-- ═══════════════════════════════════════════
     NAVIGATION
═══════════════════════════════════════════ -->
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 px-6 py-4 flex items-center justify-between">
  <!-- Logo -->
  <a href="#home" class="flex items-center gap-2 no-underline">
    <svg width="20" height="24" viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 0C10 0 4 6 4 13C4 16.866 6.686 20 10 20C13.314 20 16 16.866 16 13C16 10 14 7.5 12.5 6C12.5 6 13 9 11 11C11 11 11.5 7 10 4C10 4 8 7 8.5 10C7 8.5 6 6 6 6C4.5 8 4 10.5 4 13" fill="#C4622D"/>
      <path d="M7 14C7 14 7.5 17 10 18C12.5 17 13 14 13 14C13 14 12 16 10 16C8 16 7 14 7 14Z" fill="#E07848"/>
      <line x1="10" y1="20" x2="10" y2="24" stroke="#C4622D" stroke-width="1.5"/>
      <line x1="7" y1="23" x2="13" y2="23" stroke="#C4622D" stroke-width="1.5"/>
    </svg>
    <span style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.4rem; color:var(--cream); font-weight:400; line-height:1;">
      Ember &amp; Salt
    </span>
  </a>

  <!-- Desktop Nav -->
  <div class="hidden md:flex items-center gap-8">
    {['Menu','About','Reservations','Find Us'].map((item, i) => (
      <a
        href={`#${['menu','about','reservations','find'][i]}`}
        class="label-caps no-underline transition-colors duration-300"
        style="color:var(--cream);"
        onmouseover="this.style.color='var(--terracotta)'"
        onmouseout="this.style.color='var(--cream)'"
      >{item}</a>
    ))}
    <a href="#reservations" class="btn-terracotta" style="padding:0.6rem 1.4rem; font-size:0.65rem;">Book a Table</a>
  </div>

  <!-- Mobile Hamburger -->
  <button id="hamburger" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer border-none bg-transparent" aria-label="Open menu">
    <span class="hamburger-line block w-6 h-px transition-all duration-300" style="background:var(--cream);"></span>
    <span class="hamburger-line block w-6 h-px transition-all duration-300" style="background:var(--cream);"></span>
    <span class="hamburger-line block w-6 h-px transition-all duration-300" style="background:var(--cream);"></span>
  </button>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-400" style="background-color:var(--bg-primary);">
  <div class="flex flex-col items-center gap-10">
    {['Home','Menu','About','Reservations','Find Us'].map((item, i) => (
      <a
        href={`#${['home','menu','about','reservations','find'][i]}`}
        class="mobile-nav-link no-underline transition-colors duration-300"
        style="font-family:'Cormorant Garamond',serif; font-style:italic; font-size:3rem; color:var(--cream); font-weight:400;"
        onmouseover="this.style.color='var(--terracotta)'"
        onmouseout="this.style.color='var(--cream)'"
      >{item}</a>
    ))}
    <a href="#reservations" class="btn-terracotta mt-4 mobile-nav-link">Book a Table</a>
  </div>
</div>


<!-- ═══════════════════════════════════════════
     SECTION 1 — HERO
═══════════════════════════════════════════ -->
<section id="home" class="grain relative min-h-screen flex flex-col overflow-hidden" style="background-color:var(--bg-primary);">
  <!-- Ambient glow -->
  <div class="ember-glow" style="width:600px;height:600px;top:-100px;right:0;opacity:0.25;"></div>
  <div class="ember-glow" style="width:300px;height:300px;bottom:100px;left:10%;opacity:0.15;"></div>

  <!-- Main content -->
  <div class="relative z-10 flex flex-col md:flex-row flex-1 items-center pt-28 pb-10 px-6 md:px-16 gap-10 md:gap-0">

    <!-- Left 55% -->
    <div class="w-full md:w-[55%] md:pr-12">
      <p class="label-caps mb-6 fade-up" style="color:var(--terracotta);">Berea, Durban</p>

      <div class="overflow-hidden">
        <h1 class="font-display m-0 leading-none" style="font-family:'Cormorant Garamond',serif;">
          <span class="block fade-up stagger-1" style="font-size:clamp(64px,9vw,110px); font-style:italic; color:var(--cream); font-weight:400;">Fire.</span>
          <span class="block fade-up stagger-2" style="font-size:clamp(64px,9vw,110px); font-style:italic; color:var(--terracotta); font-weight:400; padding-left:clamp(20px,3vw,48px);">Flavour.</span>
          <span class="block fade-up stagger-3" style="font-size:clamp(64px,9vw,110px); font-style:italic; color:var(--cream); font-weight:400;">Florida Road.</span>
        </h1>
      </div>

      <p class="fade-up stagger-4 mt-8 max-w-lg leading-relaxed" style="font-family:'Jost',sans-serif; font-size:1rem; color:var(--cream); opacity:0.85;">
        Wood-fire cooking. Local ingredients. Good people. Ember &amp; Salt is Durban's favourite table — whether you stay for one course or four.
      </p>

      <div class="flex flex-wrap gap-4 mt-10 fade-up stagger-5">
        <a href="#reservations" class="btn-terracotta">Reserve a Table</a>
        <a href="#menu" class="btn-outline">View Our Menu</a>
      </div>
    </div>

    <!-- Right 45% — blob image -->
    <div class="w-full md:w-[45%] relative flex items-center justify-center" style="min-height:380px;">
      <!-- Glow behind blob -->
      <div style="position:absolute;width:460px;height:460px;border-radius:50%;background:radial-gradient(circle,rgba(196,98,45,0.25) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);"></div>

      <!-- Blob shape -->
      <div class="fade-up stagger-3 relative" style="
        width:min(420px,90vw);
        height:min(480px,70vw);
        background-color:var(--bg-warm);
        clip-path: polygon(15% 0%, 85% 3%, 98% 18%, 95% 82%, 80% 98%, 18% 97%, 2% 80%, 5% 18%);
        display:flex;align-items:center;justify-content:center;
        overflow:hidden;
      ">
        <!-- Grain inside blob -->
        <div style="position:absolute;inset:0;background-image:url(data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.07'/%3E%3C/svg%3E);background-size:200px;opacity:0.08;"></div>
        <!-- Decorative fire lines -->
        <div style="position:absolute;top:20%;left:50%;transform:translateX(-50%);width:2px;height:60%;background:linear-gradient(to bottom,var(--terracotta),transparent);opacity:0.3;"></div>
        <!-- Text -->
        <div style="position:relative;z-index:2;text-align:center;padding:2rem;">
          <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.5rem;color:var(--cream);opacity:0.6;margin:0;">[Food Photography]</p>
          <p style="font-family:'Jost',sans-serif;font-size:0.65rem;color:var(--terracotta);letter-spacing:0.2em;text-transform:uppercase;margin-top:0.5rem;opacity:0.7;">Coming Soon</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom terracotta line + marquee -->
  <div class="relative z-10">
    <div style="height:1px;background:var(--terracotta);width:100%;"></div>
    <div style="background-color:var(--bg-secondary);overflow:hidden;padding:0.85rem 0;">
      <div class="marquee-track" style="color:var(--cream);font-family:'Jost',sans-serif;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;white-space:nowrap;">
        {Array.from({length:4}).map(() => (
          <span style="padding:0 2rem;">WOOD-FIRED &nbsp;◆&nbsp; LOCALLY SOURCED &nbsp;◆&nbsp; BEREA &nbsp;◆&nbsp; OPEN TUES–SUN &nbsp;◆&nbsp; WALK-INS WELCOME &nbsp;◆&nbsp; DURBAN'S FAVOURITE TABLE &nbsp;◆&nbsp;</span>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════
     WAVY DIVIDER hero → about
═══════════════════════════════════════════ -->
<div class="wave-divider" style="background-color:var(--bg-primary); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,35 C180,70 360,0 540,35 C720,70 900,0 1080,35 C1260,70 1380,20 1440,35 L1440,70 L0,70 Z" fill="#221408"/>
  </svg>
</div>


<!-- ═══════════════════════════════════════════
     SECTION 2 — ABOUT
═══════════════════════════════════════════ -->
<section id="about" style="background-color:var(--bg-secondary);">
  <div class="flex flex-col md:flex-row min-h-[600px]">

    <!-- Left 40% — terracotta image panel -->
    <div class="w-full md:w-[40%] relative flex items-center justify-center grain" style="background-color:var(--terracotta);min-height:400px;">
      <div class="ember-glow" style="width:400px;height:400px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.2;"></div>
      <!-- Organic blob -->
      <div class="fade-up relative" style="
        width:min(340px,80vw);
        height:min(400px,75vw);
        background-color:rgba(0,0,0,0.2);
        clip-path: polygon(8% 2%, 88% 0%, 100% 15%, 96% 85%, 88% 100%, 12% 98%, 0% 82%, 4% 15%);
        display:flex;align-items:center;justify-content:center;
        border:1px solid rgba(245,237,216,0.15);
      ">
        <div style="text-align:center;padding:2rem;">
          <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.4rem;color:var(--cream);opacity:0.7;margin:0;">[Interior Shot]</p>
          <p style="font-family:'Jost',sans-serif;font-size:0.65rem;color:var(--cream);letter-spacing:0.2em;text-transform:uppercase;margin-top:0.5rem;opacity:0.5;">Coming Soon</p>
        </div>
      </div>
    </div>

    <!-- Right 60% — content -->
    <div class="w-full md:w-[60%] flex items-center px-8 md:px-16 py-16 grain" style="background-color:var(--bg-secondary);">
      <div class="max-w-xl">
        <p class="label-caps mb-5 fade-up" style="color:var(--terracotta);">Our Story</p>

        <h2 class="fade-up stagger-1 mt-0 mb-8 leading-tight" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(36px,4.5vw,56px);color:var(--cream);font-weight:400;">
          Born from a love of<br/>fire and good company
        </h2>

        <div class="fade-up stagger-2" style="font-family:'Jost',sans-serif;font-size:0.95rem;color:var(--text-secondary);line-height:1.9;">
          <p>
            Ember &amp; Salt opened its doors in 2019 in a converted warehouse on Florida Road — one of Durban's most beloved streets. We started with a single wood-fire oven, a small team and a big belief that the best meals happen when great ingredients meet real fire.
          </p>
          <p>
            Five years later we are still cooking over the same flames. Still sourcing from the same KZN farms. Still making every sauce, every bread and every dessert from scratch — every single day.
          </p>
          <p>
            This is not fine dining with rules and white tablecloths. This is good food, warm light and people who are genuinely happy to see you.
          </p>
        </div>

        <div class="fade-up stagger-3 mt-8">
          <span class="pill-badge" style="background-color:rgba(196,98,45,0.15);color:var(--terracotta);border:1px solid rgba(196,98,45,0.3);">
            🔥 Wood-fired since 2019
          </span>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════
     WAVY DIVIDER about → menu
═══════════════════════════════════════════ -->
<div class="wave-divider" style="background-color:var(--bg-secondary);margin-bottom:-2px;">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,20 C240,60 480,0 720,30 C960,60 1200,5 1440,30 L1440,70 L0,70 Z" fill="#2E1A0E"/>
  </svg>
</div>


<!-- ═══════════════════════════════════════════
     SECTION 3 — MENU HIGHLIGHTS
═══════════════════════════════════════════ -->
<section id="menu" class="grain py-20 px-6 md:px-16" style="background-color:var(--bg-warm);">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16">
      <p class="label-caps mb-4 fade-up" style="color:var(--terracotta);">From the Kitchen</p>
      <h2 class="fade-up stagger-1 mt-0 mb-4" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(40px,5vw,64px);color:var(--cream);font-weight:400;">What We're Cooking</h2>
      <p class="fade-up stagger-2 max-w-lg mx-auto" style="font-family:'Jost',sans-serif;font-size:0.95rem;color:var(--text-secondary);">A small menu done exceptionally well. Everything wood-fired. Everything fresh.</p>
    </div>

    <!-- STARTERS -->
    <div class="mb-14 fade-up">
      <div class="flex items-center gap-4 mb-8">
        <span class="label-caps" style="color:var(--terracotta);">Starters</span>
        <div style="flex:1;height:1px;background:var(--border-warm);"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          {name:'Charred Corn Soup',desc:'Slow roasted KZN corn, smoked cream, chive oil',price:'R85'},
          {name:'Wood-Fired Flatbread',desc:'House starter dough, ember butter, aged balsamic, flaked salt',price:'R65'},
          {name:'Burrata & Heritage Tomato',desc:'Creamy burrata, charred heritage tomatoes, basil oil, sourdough croutons',price:'R120'},
          {name:'Smoked Chicken Wings',desc:'12-hour smoked wings, house hot sauce, blue cheese dip',price:'R110'},
        ].map((item, i) => (
          <div class={`menu-item pb-5 fade-up stagger-${i+1}`}>
            <div class="flex justify-between items-start gap-4">
              <div>
                <p class="m-0 mb-1" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.25rem;color:var(--cream);font-weight:400;">{item.name}</p>
                <p class="m-0" style="font-family:'Jost',sans-serif;font-size:0.8rem;color:var(--text-secondary);">{item.desc}</p>
              </div>
              <span style="font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--terracotta);font-weight:500;white-space:nowrap;">{item.price}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- MAINS -->
    <div class="mb-14 fade-up">
      <div class="flex items-center gap-4 mb-8">
        <span class="label-caps" style="color:var(--terracotta);">Mains</span>
        <div style="flex:1;height:1px;background:var(--border-warm);"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          {name:'The Ember Burger',desc:'Double smash patty, aged cheddar, caramelised onion, house sauce, brioche',price:'R185'},
          {name:'Wood-Fired Linefish',desc:'Catch of the day, lemon butter, charred greens, roast potato',price:'R195'},
          {name:'Braai Pork Ribs',desc:'Full rack 8-hour smoked ribs, house BBQ, coleslaw, fries',price:'R245'},
          {name:'Mushroom & Halloumi Stack',desc:'Portobello, grilled halloumi, roast peppers, chimichurri, sourdough toast',price:'R155'},
        ].map((item, i) => (
          <div class={`menu-item pb-5 fade-up stagger-${i+1}`}>
            <div class="flex justify-between items-start gap-4">
              <div>
                <p class="m-0 mb-1" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.25rem;color:var(--cream);font-weight:400;">{item.name}</p>
                <p class="m-0" style="font-family:'Jost',sans-serif;font-size:0.8rem;color:var(--text-secondary);">{item.desc}</p>
              </div>
              <span style="font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--terracotta);font-weight:500;white-space:nowrap;">{item.price}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- DESSERTS -->
    <div class="mb-12 fade-up">
      <div class="flex items-center gap-4 mb-8">
        <span class="label-caps" style="color:var(--terracotta);">Desserts</span>
        <div style="flex:1;height:1px;background:var(--border-warm);"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          {name:'Burnt Milk Tart',desc:'House milk tart, cinnamon brûlée top, vanilla cream',price:'R75'},
          {name:'Dark Chocolate Ember Cake',desc:'Warm dark chocolate cake, salted caramel, vanilla bean ice cream',price:'R85'},
        ].map((item, i) => (
          <div class={`menu-item pb-5 fade-up stagger-${i+1}`}>
            <div class="flex justify-between items-start gap-4">
              <div>
                <p class="m-0 mb-1" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.25rem;color:var(--cream);font-weight:400;">{item.name}</p>
                <p class="m-0" style="font-family:'Jost',sans-serif;font-size:0.8rem;color:var(--text-secondary);">{item.desc}</p>
              </div>
              <span style="font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--terracotta);font-weight:500;white-space:nowrap;">{item.price}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Footer note -->
    <div style="height:1px;background:var(--terracotta);opacity:0.4;margin-bottom:2rem;"></div>
    <p class="text-center fade-up" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1rem;color:var(--text-secondary);">
      Menu changes seasonally. Speak to our team about dietary requirements.
    </p>
  </div>
</section>


<!-- ═══════════════════════════════════════════
     SECTION 4 — EXPERIENCE PANELS
═══════════════════════════════════════════ -->
<div class="wave-divider" style="background-color:var(--bg-warm);margin-bottom:-2px;">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,40 C360,10 720,65 1080,25 C1260,10 1380,50 1440,35 L1440,70 L0,70 Z" fill="#1A0F0A"/>
  </svg>
</div>

<section class="flex flex-col md:flex-row" style="min-height:500px;">

  <!-- Panel 1 — Terracotta: The Fire -->
  <div class="experience-panel w-full md:w-1/3 flex flex-col items-center justify-center px-10 py-16 text-center grain" style="background-color:var(--terracotta);min-height:400px;">
    <p class="fade-up" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(52px,6vw,80px);color:var(--cream);font-weight:300;margin:0;line-height:1;">The Fire</p>
    <p class="fade-up stagger-2 mt-6 max-w-xs" style="font-family:'Jost',sans-serif;font-size:0.85rem;color:var(--cream);opacity:0.85;line-height:1.7;">
      Our wood-fire oven burns at 400°C. Every dish passes through its flames.
    </p>
    <div class="mt-8 fade-up stagger-3">
      <svg width="40" height="50" viewBox="0 0 40 50" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 0C20 0 8 12 8 26C8 33.732 13.372 40 20 40C26.628 40 32 33.732 32 26C32 20 28 15 25 12C25 12 26 18 22 22C22 22 23 14 20 8C20 8 16 14 17 20C14 17 12 12 12 12C9 16 8 21 8 26" fill="rgba(245,237,216,0.3)"/>
      </svg>
    </div>
  </div>

  <!-- Panel 2 — Dark: Fire Photography blob -->
  <div class="experience-panel w-full md:w-1/3 flex items-center justify-center grain" style="background-color:var(--bg-primary);min-height:400px;position:relative;">
    <div class="ember-glow" style="width:350px;height:350px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.3;"></div>
    <div class="fade-up relative" style="
      width:min(300px,80vw);
      height:min(340px,70vw);
      background-color:var(--bg-warm);
      clip-path: polygon(12% 3%, 90% 0%, 100% 20%, 95% 78%, 85% 100%, 10% 96%, 0% 75%, 5% 22%);
      display:flex;align-items:center;justify-content:center;
    ">
      <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.1rem;color:var(--terracotta);opacity:0.7;margin:0;text-align:center;">[Fire Photography]</p>
    </div>
  </div>

  <!-- Panel 3 — Cream: The Salt -->
  <div class="experience-panel w-full md:w-1/3 flex flex-col items-center justify-center px-10 py-16 text-center" style="background-color:var(--cream);min-height:400px;">
    <p class="fade-up" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(52px,6vw,80px);color:var(--text-dark);font-weight:300;margin:0;line-height:1;">The Salt</p>
    <p class="fade-up stagger-2 mt-6 max-w-xs" style="font-family:'Jost',sans-serif;font-size:0.85rem;color:var(--text-dark);opacity:0.7;line-height:1.7;">
      We finish every dish with Knysna fleur de sel. Small detail. Makes everything better.
    </p>
    <div class="mt-8 fade-up stagger-3" style="width:48px;height:2px;background-color:var(--terracotta);"></div>
  </div>
</section>

<!-- Wave after panels -->
<div class="wave-divider" style="background-color:var(--cream);margin-bottom:-2px;">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,30 C200,65 450,5 720,40 C990,70 1240,10 1440,40 L1440,70 L0,70 Z" fill="#221408"/>
