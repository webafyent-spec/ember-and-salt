---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>Ember & Salt — Fire. Flavour. Florida Road. | Berea, Durban</title>
  <meta name="description" content="Wood-fire cooking on Florida Road, Berea, Durban. Local ingredients. Good people. Reserve your table at Ember & Salt." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Jost:wght@300;400;500;600&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>

<body>

<!-- ═══════════════════════════════════════════
     NAVIGATION
═══════════════════════════════════════════ -->
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 px-6 py-4 flex items-center justify-between">
  <a href="#home" class="flex items-center gap-3 no-underline group">
    <!-- Animated flickering flame SVG -->
    <svg class="nav-flame" width="18" height="26" viewBox="0 0 18 26" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M9 1C9 1 3.5 7 3.5 13.5C3.5 17.642 5.91 21 9 21C12.09 21 14.5 17.642 14.5 13.5C14.5 11 12.8 8.8 11.5 7.5C11.5 7.5 12 10.5 10 12.5C10 12.5 10.5 8.5 9 5.5C9 5.5 7 8.5 7.5 11C6 9.5 5 7 5 7C3.5 9 3.5 11.5 3.5 13.5" fill="url(#flame-grad)"/>
      <path d="M6.5 15C6.5 15 7 17.5 9 18.5C11 17.5 11.5 15 11.5 15C11.5 15 10.5 17 9 17C7.5 17 6.5 15 6.5 15Z" fill="#FFD080" opacity="0.7"/>
      <defs>
        <linearGradient id="flame-grad" x1="9" y1="1" x2="9" y2="21" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#FFE060"/>
          <stop offset="35%" stop-color="#FF8020"/>
          <stop offset="100%" stop-color="#C4622D"/>
        </linearGradient>
      </defs>
    </svg>
    <span style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.4rem;color:var(--cream);font-weight:400;line-height:1;transition:color 0.3s;">
      Ember &amp; Salt
    </span>
  </a>

  <div class="hidden md:flex items-center gap-8">
    {['Menu','About','Reservations','Find Us'].map((item, i) => (
      <a
        href={`#${['menu','about','reservations','find'][i]}`}
        class="label-caps no-underline transition-colors duration-300"
        style="color:var(--cream);"
        onmouseover="this.style.color='var(--terracotta)'"
        onmouseout="this.style.color='var(--cream)'"
      >{item}</a>
    ))}
    <a href="#reservations" class="btn-terracotta" style="padding:0.6rem 1.4rem;font-size:0.65rem;">Book a Table</a>
  </div>

  <button id="hamburger" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer border-none bg-transparent" aria-label="Open menu">
    <span class="block w-6 h-px transition-all duration-300" style="background:var(--cream);"></span>
    <span class="block w-6 h-px transition-all duration-300" style="background:var(--cream);"></span>
    <span class="block w-6 h-px transition-all duration-300" style="background:var(--cream);"></span>
  </button>
</nav>

<!-- Mobile overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none" style="background-color:var(--bg-primary);transition:opacity 0.4s ease;">
  <div class="flex flex-col items-center gap-10">
    {['Home','Menu','About','Reservations','Find Us'].map((item, i) => (
      <a href={`#${['home','menu','about','reservations','find'][i]}`}
        class="mobile-nav-link no-underline"
        style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:3rem;color:var(--cream);font-weight:400;transition:color 0.3s;"
        onmouseover="this.style.color='var(--terracotta)'"
        onmouseout="this.style.color='var(--cream)'"
      >{item}</a>
    ))}
    <a href="#reservations" class="btn-terracotta mt-4 mobile-nav-link">Book a Table</a>
  </div>
</div>


<!-- ═══════════════════════════════════════════
     SECTION 1 — HERO
═══════════════════════════════════════════ -->
<section id="home" class="grain relative min-h-screen flex flex-col overflow-hidden" style="background-color:var(--bg-primary);">

  <!-- Canvas ember particles -->
  <canvas id="ember-canvas"></canvas>

  <!-- Ambient glows -->
  <div class="ember-glow" style="width:700px;height:700px;top:-150px;right:-100px;opacity:0.2;"></div>
  <div class="ember-glow" style="width:400px;height:400px;bottom:80px;left:5%;opacity:0.12;animation-delay:1.5s;"></div>

  <!-- Main hero content -->
  <div class="relative z-10 flex flex-col md:flex-row flex-1 items-center pt-28 pb-10 px-6 md:px-16 gap-12 md:gap-0">

    <!-- Left 55% -->
    <div class="w-full md:w-[55%] md:pr-12">
      <p class="label-caps mb-6 fade-up" style="color:var(--terracotta);">Berea, Durban</p>

      <h1 class="m-0 leading-none" style="font-family:'Cormorant Garamond',serif;">
        <span class="block fade-up stagger-1" style="font-size:clamp(60px,9vw,110px);font-style:italic;color:var(--cream);font-weight:400;">Fire.</span>
        <span class="block fade-up stagger-2" style="font-size:clamp(60px,9vw,110px);font-style:italic;color:var(--terracotta);font-weight:400;padding-left:clamp(20px,3vw,48px);">Flavour.</span>
        <span class="block fade-up stagger-3" style="font-size:clamp(60px,9vw,110px);font-style:italic;color:var(--cream);font-weight:400;">Florida Road.</span>
      </h1>

      <p class="fade-up stagger-4 mt-8 max-w-lg leading-relaxed" style="font-family:'Jost',sans-serif;font-size:1rem;color:var(--cream);opacity:0.8;">
        Wood-fire cooking. Local ingredients. Good people. Ember &amp; Salt is Durban's favourite table — whether you stay for one course or four.
      </p>

      <div class="flex flex-wrap gap-4 mt-10 fade-up stagger-5">
        <a href="#reservations" class="btn-terracotta">Reserve a Table</a>
        <a href="#menu" class="btn-outline">View Our Menu</a>
      </div>
    </div>

    <!-- Right 45% — hero fire scene -->
    <div class="w-full md:w-[45%] relative flex items-center justify-center" style="min-height:420px;">

      <!-- Wide outer ember halo -->
      <div style="position:absolute;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,rgba(196,98,45,0.18) 0%,rgba(255,80,0,0.05) 50%,transparent 72%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;animation:glow-breathe 3.5s ease-in-out infinite;"></div>

      <!-- Wood-framed blob container -->
      <div class="fade-up stagger-3 relative" style="
        width:min(420px,90vw);
        height:min(500px,85vw);
        clip-path:polygon(14% 1%,84% 2%,98% 16%,96% 84%,82% 99%,16% 98%,2% 82%,4% 16%);
        overflow:hidden;
      ">
        <!-- Wood grain base -->
        <div class="wood-grain" style="position:absolute;inset:0;opacity:0.85;"></div>

        <!-- Very dark cave atmosphere — fire is the only light source -->
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(4,1,0,0.88) 0%,rgba(8,3,1,0.55) 45%,rgba(4,1,0,0.35) 100%);"></div>

        <!-- Char vignette around edges -->
        <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 60%,transparent 42%,rgba(0,0,0,0.72) 100%);"></div>

        <!-- ── FIRE SCENE ───────────────────────── -->
        <!-- Everything is positioned from the bottom, anchored to the coal bed -->
        <div id="hero-fire-scene" style="position:absolute;bottom:14%;left:50%;transform:translateX(-50%);width:240px;">

          <!-- Ground heat pool glow — wide, low, orange -->
          <div style="position:absolute;bottom:-10px;left:50%;transform:translateX(-50%);width:320px;height:80px;background:radial-gradient(ellipse,rgba(255,100,0,0.55) 0%,rgba(200,50,0,0.25) 45%,transparent 72%);animation:glow-breathe 2s ease-in-out infinite;pointer-events:none;"></div>

          <!-- ── SMOKE WISPS (above flames) ──────── -->
          <!-- wisp 1 — centre -->
          <div style="position:absolute;bottom:175px;left:50%;width:80px;height:80px;background:radial-gradient(circle,rgba(160,130,110,0.2) 0%,transparent 70%);animation:smoke-rise 4s ease-out infinite;animation-delay:0s;pointer-events:none;"></div>
          <!-- wisp 2 — left -->
          <div style="position:absolute;bottom:155px;left:28%;width:60px;height:60px;background:radial-gradient(circle,rgba(150,120,100,0.15) 0%,transparent 70%);animation:smoke-rise-b 3.5s ease-out infinite;animation-delay:0.8s;pointer-events:none;"></div>
          <!-- wisp 3 — right -->
          <div style="position:absolute;bottom:165px;left:62%;width:70px;height:70px;background:radial-gradient(circle,rgba(160,130,110,0.18) 0%,transparent 70%);animation:smoke-rise 5s ease-out infinite;animation-delay:1.6s;pointer-events:none;"></div>
          <!-- wisp 4 — wide slow -->
          <div style="position:absolute;bottom:140px;left:50%;width:100px;height:100px;background:radial-gradient(circle,rgba(140,110,90,0.1) 0%,transparent 70%);animation:smoke-rise-b 6s ease-out infinite;animation-delay:2.4s;pointer-events:none;"></div>

          <!-- ── FLAME TONGUES ────────────────────── -->
          <!-- All tongues share bottom:0 (anchored to coal bed). Each has unique animation + size. -->

          <!-- Far-left wisp tongue -->
          <div style="
            position:absolute;bottom:0;left:14%;
            width:38px;height:110px;
            background:radial-gradient(ellipse at 50% 100%,#FF7010 0%,#D83500 45%,rgba(180,20,0,0.4) 75%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-wisp-l 2.1s ease-in-out infinite;
            filter:blur(3px);
            opacity:0.55;
          "></div>

          <!-- Left tongue -->
          <div style="
            position:absolute;bottom:0;left:24%;
            width:58px;height:155px;
            background:radial-gradient(ellipse at 50% 100%,#FF8020 0%,#E84000 30%,#C02000 62%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-left 1.9s ease-in-out infinite;
            filter:blur(2px);
            opacity:0.88;
          "></div>
          <!-- Left tongue inner -->
          <div style="
            position:absolute;bottom:0;left:24%;
            width:36px;height:100px;
            background:radial-gradient(ellipse at 50% 100%,#FFD040 0%,#FF9020 45%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-left 1.55s ease-in-out infinite reverse;
            filter:blur(1px);
            opacity:0.8;
          "></div>

          <!-- Centre tongue — tallest, most prominent -->
          <div style="
            position:absolute;bottom:0;left:50%;
            width:78px;height:215px;
            background:radial-gradient(ellipse at 50% 100%,#FF6500 0%,#E03500 28%,#B81800 58%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-center 1.7s ease-in-out infinite;
            filter:blur(2.5px);
            opacity:0.95;
          "></div>
          <!-- Centre mid layer -->
          <div style="
            position:absolute;bottom:0;left:50%;
            width:55px;height:175px;
            background:radial-gradient(ellipse at 50% 100%,#FFB020 0%,#FF7000 35%,#E03200 68%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-center 1.3s ease-in-out infinite reverse;
            filter:blur(1.5px);
            opacity:0.9;
          "></div>
          <!-- Centre inner hot core -->
          <div style="
            position:absolute;bottom:0;left:50%;
            width:34px;height:130px;
            background:radial-gradient(ellipse at 50% 100%,#FFF0A0 0%,#FFD040 35%,#FF9020 65%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-center 1.05s ease-in-out infinite;
            filter:blur(0.8px);
            opacity:0.85;
          "></div>
          <!-- Centre white-hot tip -->
          <div style="
            position:absolute;bottom:0;left:50%;
            width:16px;height:80px;
            background:radial-gradient(ellipse at 50% 100%,#FFFFFF 0%,#FFFBE0 30%,#FFE060 60%,transparent 100%);
            border-radius:50% 50% 30% 30%;
            transform-origin:bottom center;
            animation:tongue-center 0.82s ease-in-out infinite reverse;
            filter:blur(0.4px);
            opacity:0.7;
          "></div>

          <!-- Right tongue -->
          <div style="
            position:absolute;bottom:0;left:56%;
            width:62px;height:165px;
            background:radial-gradient(ellipse at 50% 100%,#FF7820 0%,#E04000 32%,#C02200 64%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-right 2.05s ease-in-out infinite;
            filter:blur(2px);
            opacity:0.86;
          "></div>
          <!-- Right tongue inner -->
          <div style="
            position:absolute;bottom:0;left:56%;
            width:38px;height:108px;
            background:radial-gradient(ellipse at 50% 100%,#FFD040 0%,#FF9020 42%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-right 1.6s ease-in-out infinite reverse;
            filter:blur(1px);
            opacity:0.78;
          "></div>

          <!-- Far-right wisp tongue -->
          <div style="
            position:absolute;bottom:0;left:70%;
            width:40px;height:105px;
            background:radial-gradient(ellipse at 50% 100%,#FF6010 0%,#D53000 48%,rgba(170,15,0,0.35) 78%,transparent 100%);
            border-radius:50% 50% 28% 28%;
            transform-origin:bottom center;
            animation:tongue-wisp-r 2.3s ease-in-out infinite;
            filter:blur(3px);
            opacity:0.5;
          "></div>

          <!-- Heat shimmer layer over all flames -->
          <div style="
            position:absolute;bottom:0;left:50%;
            width:160px;height:220px;
            background:radial-gradient(ellipse at 50% 60%,rgba(255,160,60,0.04) 0%,transparent 70%);
            border-radius:50% 50% 30% 30%;
            transform-origin:bottom center;
            animation:heat-wave 2.8s ease-in-out infinite;
            pointer-events:none;
          "></div>

          <!-- ── COAL BED ─────────────────────────── -->
          <div style="position:relative;z-index:10;display:flex;align-items:flex-end;gap:4px;padding:0 8px;">
            <!-- Log 1 — back left, angled -->
            <div class="ember-coal" style="width:90px;height:20px;border-radius:10px;transform:rotate(-9deg) translateY(4px);animation-delay:0s;"></div>
            <!-- Log 2 — front centre, thick -->
            <div class="ember-coal" style="width:100px;height:24px;border-radius:12px;transform:rotate(4deg) translateY(-2px);animation-delay:0.6s;z-index:2;"></div>
            <!-- Log 3 — back right -->
            <div class="ember-coal" style="width:75px;height:18px;border-radius:9px;transform:rotate(-5deg) translateY(5px);animation-delay:1.2s;"></div>
          </div>

          <!-- Glowing ember dots on coal bed -->
          <div style="position:absolute;bottom:8px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:11;">
            <div style="width:6px;height:6px;border-radius:50%;background:#FF8020;animation:ember-dot 1.4s ease-in-out infinite;animation-delay:0s;"></div>
            <div style="width:4px;height:4px;border-radius:50%;background:#FFA030;animation:ember-dot 1.8s ease-in-out infinite;animation-delay:0.4s;"></div>
            <div style="width:7px;height:7px;border-radius:50%;background:#FF6010;animation:ember-dot 1.2s ease-in-out infinite;animation-delay:0.9s;"></div>
            <div style="width:5px;height:5px;border-radius:50%;background:#FFBB40;animation:ember-dot 2s ease-in-out infinite;animation-delay:0.2s;"></div>
            <div style="width:4px;height:4px;border-radius:50%;background:#FF7020;animation:ember-dot 1.6s ease-in-out infinite;animation-delay:1.1s;"></div>
          </div>
        </div>

        <!-- Bottom fade to black (floor of scene) -->
        <div style="position:absolute;bottom:0;left:0;right:0;height:16%;background:linear-gradient(to top,rgba(3,1,0,0.95),transparent);pointer-events:none;"></div>
        <!-- Top vignette keeps dark ceiling -->
        <div style="position:absolute;top:0;left:0;right:0;height:28%;background:linear-gradient(to bottom,rgba(3,1,0,0.9),transparent);pointer-events:none;"></div>
      </div>

      <!-- Floating outer glow synced to fire -->
      <div style="position:absolute;bottom:16%;left:50%;transform:translateX(-50%);width:220px;height:80px;background:radial-gradient(ellipse,rgba(255,100,0,0.45) 0%,transparent 70%);pointer-events:none;animation:glow-breathe 1.9s ease-in-out infinite;"></div>
    </div>
  </div>

  <!-- Plank strip accent above marquee -->
  <div class="relative z-10">
    <div class="plank-strip"></div>
    <div style="height:1px;background:var(--terracotta);width:100%;"></div>
    <div style="background-color:var(--bg-secondary);overflow:hidden;padding:0.8rem 0;">
      <div class="marquee-track" style="color:var(--cream);font-family:'Jost',sans-serif;font-size:0.68rem;letter-spacing:0.16em;text-transform:uppercase;white-space:nowrap;">
        {Array.from({length:4}).map(() => (
          <span style="padding:0 2rem;">WOOD-FIRED &nbsp;◆&nbsp; LOCALLY SOURCED &nbsp;◆&nbsp; BEREA &nbsp;◆&nbsp; OPEN TUES–SUN &nbsp;◆&nbsp; WALK-INS WELCOME &nbsp;◆&nbsp; DURBAN'S FAVOURITE TABLE &nbsp;◆&nbsp;</span>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- DIVIDER -->
<div class="wave-divider" style="background-color:var(--bg-primary);margin-bottom:-2px;">
  <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,35 C180,70 360,0 540,35 C720,70 900,0 1080,35 C1260,70 1380,20 1440,35 L1440,70 L0,70 Z" fill="#221408"/>
  </svg>
</div>


<!-- ═══════════════════════════════════════════
     SECTION 2 — ABOUT
═══════════════════════════════════════════ -->
<section id="about" style="background-color:var(--bg-secondary);">
  <div class="flex flex-col md:flex-row min-h-[600px]">

    <!-- Left — wood-grained terracotta panel -->
    <div class="w-full md:w-[40%] relative flex items-center justify-center" style="min-height:420px;overflow:hidden;">
      <!-- Wood grain base -->
      <div class="wood-grain" style="position:absolute;inset:0;"></div>
      <!-- Terracotta tint over wood -->
      <div style="position:absolute;inset:0;background:rgba(196,98,45,0.55);"></div>
      <!-- Char vignette -->
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,transparent 50%,rgba(0,0,0,0.5) 100%);"></div>
      <!-- Fire glow from bottom -->
      <div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:200px;height:120px;background:radial-gradient(ellipse,rgba(255,140,0,0.3) 0%,transparent 70%);animation:glowPulse 2.5s ease-in-out infinite;pointer-events:none;"></div>

      <!-- Organic blob -->
      <div class="fade-up relative z-10" style="
        width:min(300px,78vw);
        height:min(360px,68vw);
        background:rgba(0,0,0,0.25);
        clip-path:polygon(8% 2%,88% 0%,100% 15%,96% 85%,88% 100%,12% 98%,0% 82%,4% 15%);
        display:flex;align-items:center;justify-content:center;
        border:1px solid rgba(245,237,216,0.12);
        overflow:hidden;
      ">
        <div class="wood-grain" style="position:absolute;inset:0;opacity:0.5;"></div>
        <div style="position:absolute;inset:0;background:rgba(0,0,0,0.3);"></div>
        <div style="position:relative;z-index:2;text-align:center;padding:2rem;">
          <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.3rem;color:var(--cream);opacity:0.65;margin:0;">[Interior Shot]</p>
          <p style="font-family:'Jost',sans-serif;font-size:0.62rem;color:var(--cream);letter-spacing:0.2em;text-transform:uppercase;margin-top:0.4rem;opacity:0.4;">Coming Soon</p>
        </div>
      </div>

      <!-- Small wood knot decorations -->
      <div class="wood-knot" style="position:absolute;top:15%;right:10%;"></div>
      <div class="wood-knot" style="position:absolute;bottom:20%;left:8%;width:40px;height:28px;"></div>
    </div>

    <!-- Right — content -->
    <div class="w-full md:w-[60%] flex items-center px-8 md:px-16 py-16 grain" style="background-color:var(--bg-secondary);">
      <div class="max-w-xl">
        <p class="label-caps mb-5 fade-up" style="color:var(--terracotta);">Our Story</p>

        <!-- Decorative char line -->
        <div class="char-plank fade-up" style="width:80px;margin-bottom:1.5rem;"></div>

        <h2 class="fade-up stagger-1 mt-0 mb-8 leading-tight" style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(34px,4.5vw,54px);color:var(--cream);font-weight:400;">
          Born from a love of<br/>fire and good company
        </h2>

        <div class="fade-up stagger-2" style="font-family:'Jost',sans-serif;font-size:0.93rem;color:var(--text-secondary);line-height:1.9;">
          <p>Ember &amp; Salt opened its doors in 2019 in a converted warehouse on Florida Road — one of Durban's most beloved streets. We started with a single wood-fire oven, a small team and a big belief that the best meals happen when great ingredients meet real fire.</p>
          <p>Five years later we are still cooking over the same flames. Still sourcing from the same KZN farms. Still making every sauce, every bread and every dessert from scratch — every single day.</p>
          <p>This is not fine dining with rules and white tablecloths. This is good food, warm light and people who are genuinely happy to see you.</p>
        </div>

        <div class="fade-up stagger-3 mt-8 flex items-center gap-4 flex-wrap">
          <span class="pill-badge" style="background-color:rgba(196,98,45,0.15);color:var(--terracotta);border:1px solid rgba(196,98,45,0.3);">
            🔥 Wood-fired since 2019
          </span>
          <span class="pill-badge" style="background-color:rgba(61,36,21,0.5);color:var(--text-secondary);border:1px solid var(--border-warm);">
            🌿 KZN sourced
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Plank strip transition -->
