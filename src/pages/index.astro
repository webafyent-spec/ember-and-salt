<!-- ═══════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════ -->
<script>
// ── Nav scroll ───────────────────────────────
const nav = document.getElementById('main-nav')!;
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 60);
}, { passive: true });

// ── Hamburger ────────────────────────────────
const hamburger = document.getElementById('hamburger')!;
const mobileMenu = document.getElementById('mobile-menu')!;
let menuOpen = false;
hamburger.addEventListener('click', () => {
  menuOpen = !menuOpen;
  mobileMenu.style.opacity = menuOpen ? '1' : '0';
  mobileMenu.style.pointerEvents = menuOpen ? 'all' : 'none';
  document.body.style.overflow = menuOpen ? 'hidden' : '';
});
document.querySelectorAll('.mobile-nav-link').forEach(l =>
  l.addEventListener('click', () => {
    menuOpen = false;
    mobileMenu.style.opacity = '0';
    mobileMenu.style.pointerEvents = 'none';
    document.body.style.overflow = '';
  })
);

// ── Intersection observer fade-up ────────────
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

// ── Form submit ──────────────────────────────
function handleFormSubmit(e: Event) {
  e.preventDefault();
  const success = document.getElementById('form-success')!;
  const form = e.target as HTMLFormElement;
  (form.querySelectorAll('input,select,textarea,button') as NodeListOf<HTMLInputElement>).forEach(el => el.disabled = true);
  success.style.display = 'block';
  success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
(window as any).handleFormSubmit = handleFormSubmit;

// ── Parallax on experience panels ───────────
const panels = document.querySelectorAll<HTMLElement>('.experience-panel');
window.addEventListener('scroll', () => {
  panels.forEach((panel, i) => {
    const rect = panel.getBoundingClientRect();
    if (rect.top < window.innerHeight && rect.bottom > 0) {
      const offset = (rect.top / window.innerHeight) * 18 * (i % 2 === 0 ? 1 : -1);
      panel.style.transform = `translateY(${offset}px)`;
    }
  });
}, { passive: true });

// ════════════════════════════════════════════════
// EMBER PARTICLE SYSTEM (canvas)
// ════════════════════════════════════════════════
interface Ember {
  x: number; y: number; vx: number; vy: number;
  size: number; life: number; maxLife: number;
  color: string; rotation: number; rotVel: number;
}

function makeEmberSystem(canvasId: string, containerEl: HTMLElement | null, density = 1) {
  const canvas = document.getElementById(canvasId) as HTMLCanvasElement | null;
  if (!canvas || !containerEl) return;
  const ctx = canvas.getContext('2d')!;
  let embers: Ember[] = [];
  const COLORS = ['#FF8020','#FFA040','#FFB830','#FFD060','#FF6010','#C4622D','#E07848'];

  function resize() {
    canvas.width = containerEl.offsetWidth;
    canvas.height = containerEl.offsetHeight;
  }
  resize();
  new ResizeObserver(resize).observe(containerEl);

  function spawnEmber(x?: number, y?: number) {
    const W = canvas.width, H = canvas.height;
    embers.push({
      x: x ?? W * 0.4 + Math.random() * W * 0.25,
      y: y ?? H * 0.75 + Math.random() * H * 0.15,
      vx: (Math.random() - 0.5) * 1.2,
      vy: -(Math.random() * 2.5 + 1.2),
      size: Math.random() * 3 + 1,
      life: 0,
      maxLife: Math.random() * 120 + 80,
      color: COLORS[Math.floor(Math.random() * COLORS.length)],
      rotation: Math.random() * Math.PI * 2,
      rotVel: (Math.random() - 0.5) * 0.15,
    });
  }

  let frame = 0;
  function tick() {
    requestAnimationFrame(tick);
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    frame++;
    if (frame % Math.max(1, Math.round(4 / density)) === 0) spawnEmber();

    embers = embers.filter(e => e.life < e.maxLife);
    embers.forEach(e => {
      e.life++;
      e.x += e.vx + Math.sin(e.life * 0.06) * 0.4;
      e.y += e.vy;
      e.vy *= 0.993;
      e.rotation += e.rotVel;
      const alpha = Math.max(0, 1 - (e.life / e.maxLife) ** 1.4);
      const sz = e.size * (1 - e.life / e.maxLife * 0.5);

      ctx.save();
      ctx.globalAlpha = alpha * 0.85;
      ctx.translate(e.x, e.y);
      ctx.rotate(e.rotation);

      // Glow
      const grd = ctx.createRadialGradient(0, 0, 0, 0, 0, sz * 3);
      grd.addColorStop(0, e.color);
      grd.addColorStop(1, 'transparent');
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(0, 0, sz * 3, 0, Math.PI * 2);
      ctx.fill();

      // Core ember dot
      ctx.fillStyle = '#FFFACC';
      ctx.beginPath();
      ctx.arc(0, 0, sz * 0.5, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    });
  }
  tick();

  // Mouse interaction — hero canvas only
  if (canvasId === 'ember-canvas') {
    containerEl.addEventListener('mousemove', (ev: MouseEvent) => {
      const rect = containerEl.getBoundingClientRect();
      const mx = ev.clientX - rect.left;
      const my = ev.clientY - rect.top;
      if (Math.random() < 0.3) spawnEmber(mx + (Math.random()-0.5)*30, my + (Math.random()-0.5)*20);
    }, { passive: true });
  }
}

// Init both canvases once DOM is ready
const heroSection = document.getElementById('home');
makeEmberSystem('ember-canvas', heroSection, 1.5);

const panelSection = document.querySelector('.experience-panel:nth-child(2)') as HTMLElement | null;
makeEmberSystem('panel-ember-canvas', panelSection, 0.6);

// ════════════════════════════════════════════════
// FIRE PANEL HOVER — stoke the fire
// ════════════════════════════════════════════════
const firePanel = document.getElementById('fire-panel');
const panelFire = document.getElementById('panel-fire');
const fireGlow  = document.getElementById('fire-panel-glow');

firePanel?.addEventListener('mouseenter', () => {
  if (panelFire) {
    panelFire.style.width = '120px';
    panelFire.style.height = '170px';
    panelFire.style.transition = 'width 0.4s ease, height 0.4s ease';
  }
  if (fireGlow) {
    fireGlow.style.width = '400px';
    fireGlow.style.opacity = '1';
  }
});
firePanel?.addEventListener('mouseleave', () => {
  if (panelFire) {
    panelFire.style.width = '90px';
    panelFire.style.height = '130px';
  }
  if (fireGlow) {
    fireGlow.style.width = '300px';
    fireGlow.style.opacity = '0.6';
  }
});
</script>

